<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="ServerAppDesktop.Views.Pages.SettingsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:ServerAppDesktop.Views.Pages"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:models="using:ServerAppDesktop.Models"
	xmlns:toolkitControls="using:CommunityToolkit.WinUI.Controls"
	xmlns:toolkitExtensions="using:CommunityToolkit.WinUI"
	NavigationCacheMode="Required"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<StackPanel Grid.Row="0">
			<TextBlock x:Uid="Page_Settings_Title" Style="{StaticResource PageTitleTextBlockStyle}" />
			<InfoBar
				Title="Configuraciones no modificables"
				Margin="36,8,36,0"
				IsClosable="False"
				IsOpen="{x:Bind ViewModel.ServerRunning, Mode=OneWay}"
				Message="Algunas configuraciones no se pueden modificar mientras el servidor esté activo."
				Severity="Warning" />
		</StackPanel>

		<ScrollViewer
			Grid.Row="1"
			Padding="36"
			VerticalScrollBarVisibility="Auto"
			VerticalScrollMode="Auto">
			<StackPanel ChildrenTransitions="{StaticResource DefaultLayoutTransitions}" Spacing="{StaticResource SettingsCardSpacing}">
				<TextBlock x:Uid="AppearanceHeader" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

				<toolkitControls:SettingsCard x:Uid="BackdropSettingsCard" HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xF156;}">
					<ComboBox
						Width="170"
						ItemsSource="{x:Bind ViewModel.WindowBackdrops}"
						SelectedItem="{x:Bind ViewModel.SelectedBackdrop, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:WindowBackdrop">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard x:Uid="ThemeSettingsCard" HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE790;}">
					<ComboBox
						Width="150"
						ItemsSource="{x:Bind ViewModel.WindowThemes}"
						SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:WindowTheme">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<StackPanel>
					<toolkitControls:SettingsCard
						x:Uid="LanguageCard"
						BorderThickness="1,1,1,0"
						CornerRadius="4,4,0,0"
						HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xF2B7;}">
						<ComboBox
							Width="250"
							ItemsSource="{x:Bind ViewModel.Languages}"
							SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="models:Language">
									<TextBlock Text="{x:Bind Name}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</toolkitControls:SettingsCard>
					<InfoBar
						x:Uid="HelpTranslateBar"
						BorderThickness="1,0,1,1"
						CornerRadius="0,0,4,4"
						IsClosable="False"
						IsOpen="True"
						Severity="Informational" />
				</StackPanel>

				<TextBlock x:Uid="ServerHeader" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

				<toolkitControls:SettingsCard
					x:Uid="EditionSettingsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE7FC;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ComboBox
						Width="200"
						ItemsSource="{x:Bind ViewModel.MinecraftEditions}"
						SelectedItem="{x:Bind ViewModel.SelectedMinecraftEdition, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:MinecraftEdition">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsExpander
					x:Uid="PathSettingsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xEDA2;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<toolkitControls:SettingsExpander.Items>
						<toolkitControls:SettingsCard Header="{x:Bind ViewModel.ServerPath, Mode=OneWay}">
							<Button
								x:Uid="BrowsePathButton"
								VerticalAlignment="Center"
								Command="{x:Bind ViewModel.SelectServerPathCommand}"
								IsEnabled="{x:Bind ViewModel.CanSelectFolder, Mode=OneWay}"
								Style="{StaticResource AccentButtonStyle}">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<FontIcon Glyph="&#xE8DA;" />
									<TextBlock x:Uid="BrowsePathButtonText" />
								</StackPanel>
							</Button>
						</toolkitControls:SettingsCard>
					</toolkitControls:SettingsExpander.Items>
				</toolkitControls:SettingsExpander>

				<toolkitControls:SettingsExpander
					x:Uid="ExecutableSettingsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE943;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<toolkitControls:SettingsExpander.Items>
						<toolkitControls:SettingsCard Header="{x:Bind ViewModel.ServerExecutable, Mode=OneWay}">
							<Button
								x:Uid="BrowseExeButton"
								VerticalAlignment="Center"
								Command="{x:Bind ViewModel.SelectServerExecutableCommand}"
								IsEnabled="{x:Bind ViewModel.CanSelectExecutable, Mode=OneWay}"
								Style="{StaticResource AccentButtonStyle}">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<FontIcon Glyph="&#xE8E5;" />
									<TextBlock x:Uid="BrowseExeButtonText" />
								</StackPanel>
							</Button>
						</toolkitControls:SettingsCard>
					</toolkitControls:SettingsExpander.Items>
				</toolkitControls:SettingsExpander>

				<toolkitControls:SettingsCard
					x:Uid="PortSettingsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE839;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<NumberBox
						x:Uid="ServerPortNumberBox"
						Width="200"
						LargeChange="100"
						Maximum="65535"
						Minimum="1"
						SmallChange="1"
						Value="{x:Bind ViewModel.ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="DescriptionSettingsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE932;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<TextBox
						x:Uid="ServerDescriptionTextBox"
						MinWidth="100"
						Text="{x:Bind ViewModel.ServerDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						TextWrapping="Wrap" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="RamLimitCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE964;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<NumberBox
						Width="200"
						LargeChange="128"
						Minimum="1"
						SmallChange="16"
						SpinButtonPlacementMode="Inline"
						Value="{x:Bind ViewModel.RamLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="GamemodeCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xEA86;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ComboBox
						Width="180"
						ItemsSource="{x:Bind ViewModel.MinecraftGamemodes}"
						SelectedItem="{x:Bind ViewModel.SelectedMinecraftGamemode, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:MinecraftGamemode">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="DifficultyCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE912;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ComboBox
						Width="150"
						ItemsSource="{x:Bind ViewModel.MinecraftDifficulties}"
						SelectedItem="{x:Bind ViewModel.SelectedMinecraftDifficulty, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:MinecraftDifficulty">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="AllowCommandsCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE756;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.CommandsEnabled, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="MaxPlayersCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xEBDA;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<NumberBox
						Width="200"
						Minimum="1"
						SpinButtonPlacementMode="Inline"
						Value="{x:Bind ViewModel.MaxPlayers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="OnlineModeCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE93E;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.OnlineMode, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="LanVisibilityCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE704;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.LanVisibilty, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="ViewDistanceCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE81E;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<NumberBox
						Width="200"
						Minimum="4"
						SpinButtonPlacementMode="Inline"
						Value="{x:Bind ViewModel.ViewDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="TickDistanceCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE8B0;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<NumberBox
						Width="200"
						Minimum="1"
						SpinButtonPlacementMode="Inline"
						Value="{x:Bind ViewModel.TickDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="LevelNameCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE8AC;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<TextBox Width="200" Text="{x:Bind ViewModel.LevelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="TextureRequiredCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE7C5;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.TexturePackRequired, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="ChatRestrictionCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE8BD;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
					Visibility="{x:Bind ViewModel.SelectedMinecraftEdition, Mode=OneWay, Converter={StaticResource MinecraftEditionToVisibilityConverter}}">
					<ComboBox
						Width="180"
						ItemsSource="{x:Bind ViewModel.ChatRestrictions}"
						SelectedItem="{x:Bind ViewModel.SelectedChatRestriction, Mode=TwoWay}">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="models:ChatRestriction">
								<TextBlock Text="{x:Bind Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="PlayerInteractionCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xEDA4;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
					Visibility="{x:Bind ViewModel.SelectedMinecraftEdition, Mode=OneWay, Converter={StaticResource MinecraftEditionToVisibilityConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.PlayerInteraction, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard
					x:Uid="ForceGamemodeCard"
					HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE727;}"
					IsEnabled="{x:Bind ViewModel.ServerRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.ForceGamemode, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<TextBlock x:Uid="StartupHeader" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

				<toolkitControls:SettingsCard x:Uid="StartupWindowsCard">
					<toolkitControls:SettingsCard.HeaderIcon>
						<PathIcon Data="{StaticResource WindowsIconPath}" />
					</toolkitControls:SettingsCard.HeaderIcon>
					<ToggleSwitch IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard x:Uid="CloseTrayCard" HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE944;}">
					<ToggleSwitch IsOn="{x:Bind ViewModel.CloseInSystemTray, Mode=TwoWay}" />
				</toolkitControls:SettingsCard>

				<toolkitControls:SettingsCard x:Uid="AutoStartSettingsCard" HeaderIcon="{toolkitExtensions:FontIcon Glyph=&#xE78B;}">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<InfoBadge Style="{StaticResource CautionIconInfoBadgeStyle}" />
						<ToggleSwitch x:Uid="AutoStartToggleSwitch" IsOn="{x:Bind ViewModel.AutoStartServer, Mode=TwoWay}" />
					</StackPanel>
				</toolkitControls:SettingsCard>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>
