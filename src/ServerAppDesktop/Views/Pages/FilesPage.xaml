<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="ServerAppDesktop.Views.Pages.FilesPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:ServerAppDesktop.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:dev="using:DevWinUI"
	xmlns:local="using:ServerAppDesktop.Views.Pages"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:models="using:ServerAppDesktop.Models"
	xmlns:toolkitControls="using:CommunityToolkit.WinUI.Controls"
	xmlns:toolkitExtensions="using:CommunityToolkit.WinUI"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<TextBlock
			x:Uid="Page_Files_Title"
			Grid.Row="0"
			Style="{StaticResource PageTitleTextBlockStyle}" />
		<Grid Grid.Row="1" Padding="36">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<Border
				Grid.Row="0"
				Padding="12"
				HorizontalAlignment="Left"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="{StaticResource ControlCornerRadius}">
				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<FontIcon
						Grid.Column="0"
						FontSize="24"
						Glyph="&#xE958;" />
					<Grid Grid.Column="1">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock
							x:Uid="DiskLabel"
							Grid.Row="0"
							Style="{StaticResource BodyStrongTextBlockStyle}" />
						<ProgressBar
							Grid.Row="1"
							Margin="0,8"
							Value="6.2" />
						<TextBlock
							x:Uid="DiskAvailableText"
							Grid.Row="2"
							Style="{StaticResource CaptionTextBlockStyle}" />
					</Grid>
				</Grid>
			</Border>

			<Grid Grid.Row="1" Margin="0,36,0,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Orientation="Horizontal">
					<CommandBar HorizontalAlignment="Left" DefaultLabelPosition="Right">
						<AppBarButton x:Uid="NewFileBtn" Icon="{dev:ThemedIcon IconType=Layered, Style={StaticResource App.ThemedIcons.New.Item}}">
							<AppBarButton.Flyout>
								<MenuFlyout Placement="Bottom">
									<MenuFlyoutItem x:Uid="NewFolderItem" Icon="{toolkitExtensions:BitmapIcon Source=/Assets/Files/NewFolder.png}" />
									<MenuFlyoutItem x:Uid="NewFileItem" Icon="{toolkitExtensions:BitmapIcon Source=/Assets/Files/NewFile.png}" />
								</MenuFlyout>
							</AppBarButton.Flyout>
						</AppBarButton>
					</CommandBar>
					<AppBarSeparator />
					<CommandBar HorizontalAlignment="Left" DefaultLabelPosition="Collapsed">
						<AppBarButton
							x:Uid="RefreshBtn"
							MaxWidth="46"
							Icon="Refresh" />
						<AppBarSeparator />
						<AppBarButton
							x:Uid="CutBtn"
							MaxWidth="46"
							Icon="{dev:ThemedIcon IconType=Layered,
												  Style={StaticResource App.ThemedIcons.Cut}}" />
						<AppBarButton
							x:Uid="CopyBtn"
							MaxWidth="46"
							Icon="{dev:ThemedIcon IconType=Layered,
												  Style={StaticResource App.ThemedIcons.Copy}}" />
						<AppBarButton
							x:Uid="PasteBtn"
							MaxWidth="46"
							Icon="{dev:ThemedIcon IconType=Layered,
												  Style={StaticResource App.ThemedIcons.Paste}}" />
						<AppBarSeparator />
						<AppBarButton
							x:Uid="RenameBtn"
							MaxWidth="46"
							Icon="{dev:ThemedIcon IconType=Layered,
												  Style={StaticResource App.ThemedIcons.Rename}}" />
						<AppBarButton
							x:Uid="DeleteBtn"
							MaxWidth="46"
							Icon="{dev:ThemedIcon IconType=Layered,
												  Style={StaticResource App.ThemedIcons.Delete}}" />
						<AppBarSeparator />
						<AppBarButton
							x:Uid="PropertiesBtn"
							MaxWidth="46"
							Icon="Repair" />
					</CommandBar>
					<AppBarSeparator />
					<CommandBar HorizontalAlignment="Left" DefaultLabelPosition="Right">
						<AppBarButton x:Uid="BackupBtn" Icon="{toolkitExtensions:BitmapIcon Source=/Assets/Files/Backup.png}" />
						<AppBarButton x:Uid="OpenFolderBtn" Icon="{toolkitExtensions:BitmapIcon Source=/Assets/Files/OpenFolder.png}" />
					</CommandBar>
				</StackPanel>

				<Border
					Grid.Row="1"
					Padding="16,0"
					Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1"
					CornerRadius="{StaticResource OverlayCornerRadius}">
					<ListView>
						<ListView.Header>
							<toolkitControls:DataTable Margin="12,16,0,0">
								<toolkitControls:DataColumn DesiredWidth="Auto" />
								<toolkitControls:DataColumn
									x:Uid="ColName"
									CanResize="True"
									DesiredWidth="3*" />
								<toolkitControls:DataColumn
									x:Uid="ColSize"
									CanResize="True"
									DesiredWidth="*" />
								<toolkitControls:DataColumn
									x:Uid="ColDate"
									CanResize="True"
									DesiredWidth="*" />
								<toolkitControls:DataColumn x:Uid="ColEditable" DesiredWidth="Auto" />
							</toolkitControls:DataTable>
						</ListView.Header>
						<ListView.ContextFlyout>
							<MenuFlyout>
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutCut" ThemedIconStyle="{StaticResource App.ThemedIcons.Cut}" />
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutCopy" ThemedIconStyle="{StaticResource App.ThemedIcons.Copy}" />
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutPaste" ThemedIconStyle="{StaticResource App.ThemedIcons.Paste}" />
								<MenuFlyoutSeparator />
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutRename" ThemedIconStyle="{StaticResource App.ThemedIcons.Rename}" />
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutDelete" ThemedIconStyle="{StaticResource App.ThemedIcons.Delete}" />
								<MenuFlyoutSeparator />
								<controls:MenuFlyoutItemWithThemedIcon x:Uid="FlyoutProps" Icon="Repair" />
							</MenuFlyout>
						</ListView.ContextFlyout>
					</ListView>
				</Border>
			</Grid>
		</Grid>
	</Grid>
</Page>
